# 阿里云 Prometheus Pushgateway 配置（可选）
# 如果配置了以下参数，Rust Exporter 会自动推送指标到阿里云
# 同时本地 /metrics 端点仍然可用

# Pushgateway URL（公网地址）
# 示例：https://workspace-default-cms-xxx.log.aliyuncs.com/prometheus/workspace-xxx/aliyun-prom-xxx/api/v1/pushgateway
PUSHGATEWAY_URL=

# Job 名称（默认：rust-exporter）
PUSHGATEWAY_JOB=channel-health-exporter

# 阿里云 AccessKey（需要有 AliyunPrometheusMetricWriteAccess 权限）
PUSHGATEWAY_USERNAME=
PUSHGATEWAY_PASSWORD=

# 推送间隔（秒，默认：60）
PUSHGATEWAY_INTERVAL=60
